<UserControl x:Class="MCGCadPlugin.Views.CheckList.QaChecklistView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="400"
             Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
             Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
             FontFamily="Segoe UI">

    <!-- Định nghĩa các kiểu dáng điều khiển chuẩn liên kết động SystemColors -->
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <!-- 0. Header & Thanh công cụ nạp file -->
            <RowDefinition Height="Auto"/>
            <!-- 1. Thước đo tiến trình (Progress) -->
            <RowDefinition Height="Auto"/>
            <!-- 2. Lưới danh sách câu hỏi -->
            <RowDefinition Height="*"/>
            <!-- 3. Thêm câu hỏi Custom -->
            <RowDefinition Height="Auto"/>
            <!-- 4. Phê duyệt & Ký duyệt -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 0. Header & Thanh công cụ nạp file -->
        <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" Padding="0,0,0,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="MCG CHECKLIST" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text="MacGregor Quality Control" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="10" Margin="0,2,0,0"/>
                    <!-- Dòng trạng thái Vault: ẩn khi chưa load (SyncStatusText rỗng), hover để xem lỗi đầy đủ -->
                    <TextBlock Text="{Binding SyncStatusText}" Foreground="{Binding SyncStatusColor}"
                               FontSize="9" Margin="0,3,0,0" Cursor="Help"
                               ToolTip="{Binding Document.SyncMessage}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SyncStatusText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Dropdown chọn loại bản vẽ mẫu (Khóa khi đang đồng bộ) -->
                <ComboBox Grid.Column="1" x:Name="CboDiscipline" SelectionChanged="CboDiscipline_SelectionChanged"
                          Width="130" Height="28" VerticalAlignment="Center" Margin="5,0,0,0"
                          Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                          Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                          BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                          IsEnabled="{Binding IsNotLoading}"
                          FontSize="11" Padding="4,2" Cursor="Hand" ToolTip="Select drawing type to automatically load template">
                    <ComboBox.Resources>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"/>
                            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                            <Setter Property="Padding" Value="6,4"/>
                        </Style>
                    </ComboBox.Resources>
                    <ComboBoxItem Content="Layout / Interface" Tag="Temp Checklist - LayoutInterface.xlsx"/>
                    <ComboBoxItem Content="Mechanical" Tag="Temp Checklist - Mechanical.xlsx"/>
                    <ComboBoxItem Content="Structure" Tag="Temp Checklist - Structure.xlsx"/>
                </ComboBox>

                <!-- Nút nạp Excel thủ công (Khóa khi đang đồng bộ) -->
                <Button Grid.Column="2" Content="..." Click="BtnLoadExcel_Click"
                        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                        Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1"
                        IsEnabled="{Binding IsNotLoading}"
                        Width="28" Height="28" Margin="4,0,0,0" FontSize="12" FontWeight="Bold" Cursor="Hand" ToolTip="Manually load Excel file from another location"/>

                <!-- Nút đóng nhanh Palette (✕) -->
                <Button Grid.Column="3" Content="✕" Click="BtnClosePalette_Click"
                        Background="Transparent" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" BorderThickness="0"
                        Padding="8,4" FontSize="14" FontWeight="Bold" Margin="6,0,0,0" Cursor="Hand" ToolTip="Close Palette">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderThickness="0" CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#FFFF4D4D"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- 1. Thước đo tiến trình -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Checklist Progress" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" FontSize="11" Margin="0,0,0,4"/>
            <TextBlock Grid.Column="1" Text="{Binding ProgressText, FallbackValue='0%'}" Foreground="#FF0078D4" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>

            <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Height="6" Minimum="0" Maximum="100" Value="{Binding ProgressValue}"
                         Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" Foreground="#FF0078D4" BorderThickness="0">
                <ProgressBar.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="3"/>
                    </Style>
                </ProgressBar.Resources>
            </ProgressBar>
        </Grid>

        <!-- 2a. Empty state — hiển thị khi chưa chọn loại bản vẽ -->
        <Border Grid.Row="2" BorderThickness="1" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" CornerRadius="4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Document}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                <TextBlock Text="↑  Select a drawing type above" FontSize="13" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                <TextBlock Text="to load the checklist for this drawing" FontSize="11" Margin="0,6,0,0"
                           HorizontalAlignment="Center" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
            </StackPanel>
        </Border>

        <!-- 2b. Lưới danh sách câu hỏi -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding ChecklistItems}" AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False" GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" Background="Transparent" BorderThickness="0"
                  RowHeaderWidth="0" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                  RowBackground="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                  AlternatingRowBackground="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
            <DataGrid.Resources>
                <!-- Kiểu dáng phần Header của DataGrid -->
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>
                    <Setter Property="Padding" Value="4,6"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="4"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type DataGridCell}">
                                <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                    <ContentPresenter SnapsToDevicePixels="True"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <!-- Cột Tickbox trạng thái (Khóa khi đang đồng bộ bận hoặc item là N/A) -->
                <DataGridTemplateColumn Width="40" Header="✓">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate d:DataContext="{d:DesignInstance Type=ChecklistItem}">
                            <CheckBox IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand">
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="IsEnabled" Value="{Binding DataContext.IsGridEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        <Style.Triggers>
                                            <!-- Khi N/A: làm mờ và vô hiệu hóa ô tick -->
                                            <DataTrigger Binding="{Binding IsNotApplicable}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                                <Setter Property="Opacity" Value="0.25"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Cột nội dung câu hỏi -->
                <DataGridTemplateColumn Width="*" Header="Checklist Item Content">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate d:DataContext="{d:DesignInstance Type=ChecklistItem}">
                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Margin="4" FontSize="11" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                                        <Style.Triggers>
                                            <!-- Khi N/A: làm mờ nội dung và gạch ngang -->
                                            <DataTrigger Binding="{Binding IsNotApplicable}" Value="True">
                                                <Setter Property="Opacity" Value="0.35"/>
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate d:DataContext="{d:DesignInstance Type=ChecklistItem}">
                            <TextBox Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap"
                                     Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                                     Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                                     BorderBrush="#FF0078D4"
                                     IsEnabled="{Binding IsCustom}" FontSize="11"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Cột N/A — áp dụng cho tất cả items (cả standard và custom) -->
                <DataGridTemplateColumn Width="45" Header="N/A">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate d:DataContext="{d:DesignInstance Type=ChecklistItem}">
                            <CheckBox IsChecked="{Binding IsNotApplicable, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand"
                                      IsEnabled="{Binding DataContext.IsGridEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Cột thao tác xóa -->
                <DataGridTemplateColumn Width="50" Header="Delete">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate d:DataContext="{d:DesignInstance Type=ChecklistItem}">
                            <Button Content="✕" Click="BtnDeleteCustomItem_Click" Background="Transparent" Foreground="#FFFF4D4D" BorderThickness="0"
                                    FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand"
                                    Visibility="{Binding IsCustom, Converter={StaticResource BoolToVisConverter}}"
                                    IsEnabled="{Binding DataContext.IsGridEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 3. Thêm câu hỏi Custom -->
        <Border Grid.Row="3" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" BorderThickness="1" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" CornerRadius="4" Padding="6" Margin="0,10,0,10"
                Visibility="{Binding IsGridEnabled, Converter={StaticResource BoolToVisConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtCustomItem" Margin="2"
                         Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                         Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                         BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" Padding="4" FontSize="11"
                         GotFocus="TxtCustomItem_GotFocus" LostFocus="TxtCustomItem_LostFocus"/>
                <Button Grid.Column="1" Content="ADD NEW" Click="BtnAddCustomItem_Click" Margin="4,2,2,2" Padding="12,4"
                        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                        Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" FontSize="10" FontWeight="SemiBold" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- 4. Phê duyệt & Ký duyệt -->
        <Border Grid.Row="4" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" BorderThickness="1" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" CornerRadius="4" Padding="10">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="DOCUMENT STATUS:" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="10" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Document.Status, FallbackValue='PENDING'}" Foreground="{Binding StatusColor}" FontSize="12" FontWeight="Bold" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Nút ký duyệt Approve -->
                    <Button Grid.Column="1" Content="APPROVE" Click="BtnApprove_Click"
                            Visibility="{Binding IsGridEnabled, Converter={StaticResource BoolToVisConverter}}"
                            Background="#FF228B22" Foreground="White" BorderThickness="0" Padding="16,8" FontWeight="Bold" FontSize="11" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="3"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <!-- Nút khôi phục PENDING (chỉ hiện khi đã APPROVED) -->
                    <Button Grid.Column="1" Content="RE-OPEN" Click="BtnReopen_Click"
                            Visibility="{Binding IsApproved, Converter={StaticResource BoolToVisConverter}}"
                            Background="#FFD32F2F" Foreground="White" BorderThickness="0" Padding="16,8" FontWeight="Bold" FontSize="11" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="3"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <StackPanel Visibility="{Binding IsApproved, Converter={StaticResource BoolToVisConverter}}">
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Approved By:" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="{Binding Document.ApprovedBy}" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" FontSize="10" FontWeight="SemiBold"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Approved Date:" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="{Binding Document.ApprovedDate}" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" FontSize="10" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ================================================================= -->
        <!-- THÊM MỚI: Lớp phủ khóa màn hình khi đang thực thi Asynchronous   -->
        <!-- ================================================================= -->
        <Grid Grid.Row="1" Grid.RowSpan="4" Background="#40000000"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConverter}}">
            <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                    BorderThickness="1" CornerRadius="5" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="25,15">
                <StackPanel HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="180" Height="8" Margin="0,0,0,10" Foreground="#FF0078D4"/>
                    <TextBlock Text="Syncing with Vault Server..." HorizontalAlignment="Center" FontWeight="Bold" FontSize="11" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                    <TextBlock Text="Please wait a moment..." FontSize="9" Margin="0,3,0,0" HorizontalAlignment="Center" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                </StackPanel>
            </Border>
        </Grid>
        <!-- ================================================================= -->
    </Grid>
</UserControl>
